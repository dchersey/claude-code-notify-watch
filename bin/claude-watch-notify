#!/bin/bash
# claude-watch-notify — Claude Code hook → local claude-watch relay.
#
# Reads one hook-event JSON object on stdin, maps it to a compact event, and
# POSTs it to the relay (http://127.0.0.1:4747/claude/event) FULLY DETACHED.
# It ALWAYS exits 0 immediately, so a slow/down relay can never stall or error
# Claude Code. Wired from ~/.claude/settings.json hooks (Notification +
# SubagentStop). Apple-signed /bin/bash + absolute tool paths per global rules.

RELAY_URL="${CLAUDE_WATCH_URL:-http://127.0.0.1:4747/claude/event}"
CONNECT_TIMEOUT=1
MAX_TIME=2
# Resolve tools portably — hooks may run with a minimal PATH, and jq may live
# under Homebrew rather than /usr/bin.
JQ="$(command -v jq 2>/dev/null || true)"
[ -z "$JQ" ] && for p in /opt/homebrew/bin/jq /usr/local/bin/jq /usr/bin/jq; do
  [ -x "$p" ] && { JQ="$p"; break; }
done
CURL="$(command -v curl 2>/dev/null || echo /usr/bin/curl)"

# Read stdin once. Empty → nothing to do.
INPUT="$(cat 2>/dev/null)"
[ -z "$INPUT" ] && exit 0

# Need jq and valid JSON; otherwise no-op (never error).
command -v "$JQ" >/dev/null 2>&1 || exit 0
printf '%s' "$INPUT" | "$JQ" -e . >/dev/null 2>&1 || exit 0

# Coarse kind first (cheap) so non-actionable events (auth_success, elicitation_*,
# ...) are skipped entirely.
KIND="$(printf '%s' "$INPUT" | "$JQ" -r '
  ( .hook_event_name // "" ) as $ev | ( .notification_type // "" ) as $nt |
  if   $ev == "SubagentStop"      then "subagent"
  elif $nt == "idle_prompt"       then "done"
  elif $nt == "permission_prompt" then "permission"
  else "notify" end' 2>/dev/null)"
case "$KIND" in done|permission|subagent) ;; *) exit 0 ;; esac

# Send this pane's zellij identity (pane id + session); the RELAY resolves the tab
# name from these (cached). Keeps the hook INSTANT — no `zellij list-panes` here,
# which takes ~2s in a busy session (it raced the old timeout, dropping the tab,
# and added ~2s of notification lag).
PAYLOAD="$(
  printf '%s' "$INPUT" | "$JQ" -c \
    --arg kind "$KIND" \
    --arg pid "${ZELLIJ_PANE_ID:-}" \
    --arg zsession "${ZELLIJ_SESSION_NAME:-}" '
    ( .cwd // "" )                     as $cwd |
    ( $cwd | split("/") | last // "" ) as $project |
    ( .session_id // "" )              as $sid |
    {
      kind:           $kind,
      message:        ( .message // "" ),
      project:        $project,
      pane_id:        $pid,
      zellij_session: $zsession,
      cwd:            $cwd,
      session_id:     $sid,
      agent_type:     ( .agent_type // null ),
      ts:             ( now | floor ),
      dedup_key:      ( $sid + ":" + $kind )
    }
  ' 2>/dev/null
)"
[ -z "$PAYLOAD" ] && exit 0

# Fire-and-forget: detached, output discarded, hard time caps so a hung network
# or down relay can never outlive ~2s and never blocks this script. If a shared
# secret is configured (env, else the claude-watch-shared-secret Keychain item),
# send it as X-Claude-Watch-Secret so a secret-guarded relay accepts the POST.
# Resolved inside the detached block so it never delays this script's fast exit.
{
  SECRET="${CLAUDE_WATCH_SECRET:-}"
  if [ -z "$SECRET" ]; then
    SEC="$(command -v security 2>/dev/null || echo /usr/bin/security)"
    # $(...) strips the trailing newline `security -w` adds, so the header is clean.
    [ -x "$SEC" ] && SECRET="$("$SEC" find-generic-password -s claude-watch-shared-secret -w 2>/dev/null)"
  fi
  HDR=()
  [ -n "$SECRET" ] && HDR=(-H "X-Claude-Watch-Secret: $SECRET")
  "$CURL" -sS -X POST "$RELAY_URL" \
    -H 'Content-Type: application/json' \
    "${HDR[@]}" \
    --connect-timeout "$CONNECT_TIMEOUT" \
    --max-time "$MAX_TIME" \
    --data-binary "$PAYLOAD" \
    >/dev/null 2>&1
} &
disown 2>/dev/null

exit 0
